<div class="widget-wrap widget-site-info">
  <h3 class="widget-title">📊 网站资讯</h3>
  <div class="widget" style="font-size: 14px; line-height: 2; color: #6b8a86;">
    <div class="site-info-item">
      <span class="info-label">文章数目 :</span>
      <span class="info-value"><%= site.posts.length %></span>
    </div>
    <div class="site-info-item">
      <span class="info-label">已运行时间 :</span>
      <span class="info-value" id="site-runtime">1 天</span>
    </div>
    <div class="site-info-item">
      <span class="info-label">本站总字数 :</span>
      <span class="info-value" id="site-wordcount">0</span>
    </div>
    <div class="site-info-item">
      <span class="info-label">本站访客数 :</span>
      <span class="info-value" id="busuanzi_value_site_uv">--</span>
    </div>
    <div class="site-info-item">
      <span class="info-label">本站总访问量 :</span>
      <span class="info-value" id="busuanzi_value_site_pv">--</span>
    </div>
    <div class="site-info-item">
      <span class="info-label">最后更新时间 :</span>
      <span class="info-value"><%= date(site.posts.sort('date', -1).first().date, 'YYYY-MM-DD') %></span>
    </div>
  </div>
</div>

<script>
  // 运行时间自动计算
  (function() {
    var start = new Date('2026-06-05');
    var now = new Date();
    var days = Math.floor((now - start) / (1000 * 60 * 60 * 24));
    var el = document.getElementById('site-runtime');
    if (el) el.textContent = days + ' 天';
  })();
</script>

<!-- 不蒜子 访客统计 -->
<script async src="https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>

<style>
  .widget-site-info .site-info-item {
    display: flex;
    justify-content: space-between;
    padding: 4px 0;
  }
  .widget-site-info .info-label {
    color: #8ba3a0;
  }
  .widget-site-info .info-value {
    color: #4eb8a8;
    font-weight: 600;
  }

  /* 标签小方框样式 */
  .widget.tagcloud a,
  .tagcloud a {
    display: inline-block;
    margin: 3px 4px;
    padding: 4px 12px;
    background: #eef7f5;
    color: #4eb8a8 !important;
    border: 1px solid #c8e0dc;
    border-radius: 15px;
    font-size: 13px !important;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .widget.tagcloud a:hover,
  .tagcloud a:hover {
    background: #4eb8a8 !important;
    color: #fff !important;
    border-color: #4eb8a8;
  }
</style>
