<nav id="mobile-nav">
  <%
    var menuIcons = {
      Home: 'fa-home',
      Archives: 'fa-archive',
      Links: 'fa-link',
      About: 'fa-user'
    };
    for (var i in theme.menu){
  %>
    <a href="<%- url_for(theme.menu[i]) %>" class="mobile-nav-link"><span class="fa <%- menuIcons[i] || 'fa-circle' %>"></span> <%= i %></a>
  <% } %>
</nav>