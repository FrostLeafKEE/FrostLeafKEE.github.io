<!-- 全屏风景图 Hero -->
<div class="hero-fullscreen" style="
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  margin: 0;
  padding: 0;
">
  <img src="/img/fengjing.png" alt="风景" style="
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  ">

  <!-- 打字机文字层 -->
  <div class="hero-typewriter" style="
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 10;
    pointer-events: none;
  ">
    <h1 id="tw-title" style="
      font-size: 48px;
      font-weight: 700;
      color: #fff;
      text-shadow: 0 2px 12px rgba(0,0,0,0.6);
      margin: 0 0 16px 0;
      font-family: 'Courier New', monospace;
      min-height: 60px;
      letter-spacing: 2px;
    "></h1>
    <p id="tw-subtitle" style="
      font-size: 20px;
      color: rgba(255,255,255,0.9);
      text-shadow: 0 1px 8px rgba(0,0,0,0.5);
      margin: 0;
      font-family: 'Courier New', monospace;
      min-height: 28px;
    "></p>
  </div>

  <!-- 向下滚动指示标 -->
  <div class="scroll-indicator" style="
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    animation: scrollBounce 2s ease-in-out infinite;
    cursor: pointer;
    z-index: 10;
  " onclick="document.querySelector('.outer').scrollIntoView({behavior: 'smooth'});">
    <span class="fa fa-chevron-down" style="
      font-size: 36px;
      color: #fff;
      text-shadow: 0 2px 8px rgba(0,0,0,0.5);
    "></span>
  </div>
</div>

<style>
  /* 隐藏首页 Logo 标题和 banner 白线 */
  #header-title { display: none !important; }
  #header #banner { display: none !important; }
  #header:before,
  #header:after { display: none !important; }
  #header { border-bottom: none !important; }
  #header-outer { border-bottom: none !important; }

  /* Header 透明悬浮在 Hero 之上 */
  #header {
    position: absolute !important;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 50px !important;
    background: transparent !important;
  }
  #header-outer {
    height: 50px !important;
  }
  #header-inner {
    padding: 10px 0 !important;
  }
  #main-nav {
    margin-top: 0 !important;
  }
  #header .main-nav-link,
  #header #logo,
  #header .nav-icon {
    color: #fff !important;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    line-height: 30px !important;
  }
  #header .main-nav-link:hover {
    color: rgba(255,255,255,0.8) !important;
  }

  /* 打字机光标闪烁 */
  #tw-title::after,
  #tw-subtitle::after {
    content: '|';
    animation: tw-blink 0.8s step-end infinite;
    color: #fff;
    text-shadow: 0 1px 6px rgba(0,0,0,0.5);
  }
  @keyframes tw-blink {
    50% { opacity: 0; }
  }

  /* 滚动指示标动画 */
  @keyframes scrollBounce {
    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
    40% { transform: translateX(-50%) translateY(-12px); }
    60% { transform: translateX(-50%) translateY(-6px); }
  }
</style>

<script>
(function() {
  const titleEl = document.getElementById('tw-title');
  const subEl = document.getElementById('tw-subtitle');

  const titleText = 'FrostLeafKEE';
  const sentences = [
    '欢迎来到我的博客 🍃',
    '记录生活的点点滴滴',
    '分享技术与热爱',
    '二次元爱好者 | 昆虫迷',
    '学生一枚，请多关照',
    '每一天都是新的开始',
    '霜叶红于二月花',
    '遇见困难睡大觉'
  ];

  let sentenceIndex = 0;

  function type(el, text, speed, callback) {
    let i = 0;
    el.textContent = '';
    function tick() {
      if (i < text.length) {
        el.textContent += text.charAt(i);
        i++;
        setTimeout(tick, speed);
      } else if (callback) {
        callback();
      }
    }
    tick();
  }

  function erase(el, speed, callback) {
    function tick() {
      const text = el.textContent;
      if (text.length > 0) {
        el.textContent = text.slice(0, -1);
        setTimeout(tick, speed);
      } else if (callback) {
        callback();
      }
    }
    tick();
  }

  function nextSentence() {
    const sentence = sentences[sentenceIndex % sentences.length];
    sentenceIndex++;
    type(subEl, sentence, 80, function() {
      // 全部打出后停留 10 秒
      setTimeout(function() {
        erase(subEl, 40, function() {
          // 删完后停顿一下再出下一句
          setTimeout(nextSentence, 400);
        });
      }, 10000);
    });
  }

  // 启动：先打出名字，再开始循环句子
  type(titleEl, titleText, 100, function() {
    setTimeout(nextSentence, 600);
  });
})();
</script>
