<!-- 全屏风景图 Hero -->
<div class="hero-fullscreen" style="
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  margin: 0;
  padding: 0;
">
  <img src="/img/fengjing.png" alt="风景" style="
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  ">

  <!-- 打字机文字层 -->
  <div class="hero-typewriter" style="
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 10;
    pointer-events: none;
  ">
    <h1 id="tw-title" style="
      font-size: 48px;
      font-weight: 700;
      color: #fff;
      text-shadow: 0 2px 12px rgba(0,0,0,0.6);
      margin: 0 0 16px 0;
      font-family: 'Courier New', monospace;
      min-height: 60px;
      letter-spacing: 2px;
    "></h1>
    <p id="tw-subtitle" style="
      font-size: 20px;
      color: rgba(255,255,255,0.9);
      text-shadow: 0 1px 8px rgba(0,0,0,0.5);
      margin: 0;
      font-family: 'Courier New', monospace;
      min-height: 28px;
    "></p>
  </div>

  <!-- 向下滚动指示标 -->
  <div class="scroll-indicator" style="
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    cursor: pointer;
    z-index: 10;
  " onclick="document.querySelector('.outer').scrollIntoView({behavior: 'smooth'});">
    <span class="fa fa-chevron-down scroll-arrow" style="
      font-size: 22px;
      color: #fff;
      text-shadow: 0 2px 8px rgba(0,0,0,0.5);
      opacity: 0.45;
      animation: scrollArrow 2s ease-in-out infinite;
    "></span>
    <span class="fa fa-chevron-down scroll-arrow" style="
      font-size: 28px;
      color: #fff;
      text-shadow: 0 2px 8px rgba(0,0,0,0.5);
      opacity: 0.7;
      animation: scrollArrow 2s ease-in-out 0.2s infinite;
    "></span>
    <span class="fa fa-chevron-down scroll-arrow" style="
      font-size: 36px;
      color: #fff;
      text-shadow: 0 2px 8px rgba(0,0,0,0.5);
      opacity: 1;
      animation: scrollArrow 2s ease-in-out 0.4s infinite;
    "></span>
  </div>
</div>

<style>
  /* 隐藏首页 Logo 标题和 banner 白线 */
  #header-title { display: none !important; }
  #header #banner { display: none !important; }
  #header:before,
  #header:after { display: none !important; }
  #header { border-bottom: none !important; }
  #header-outer { border-bottom: none !important; }

  /* Header 透明悬浮在 Hero 之上 */
  #header {
    position: absolute !important;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 50px !important;
    background: transparent !important;
  }
  #header-outer {
    height: 50px !important;
  }
  #header-inner {
    padding: 10px 0 !important;
  }
  #main-nav {
    margin-top: 0 !important;
  }
  #header .main-nav-link,
  #header #logo,
  #header .nav-icon {
    color: #fff !important;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    line-height: 30px !important;
  }
  #header .main-nav-link:hover {
    color: rgba(255,255,255,0.8) !important;
  }

  /* 打字机光标闪烁 */
  #tw-title::after,
  #tw-subtitle::after {
    content: '|';
    animation: tw-blink 0.8s step-end infinite;
    color: #fff;
    text-shadow: 0 1px 6px rgba(0,0,0,0.5);
  }
  @keyframes tw-blink {
    50% { opacity: 0; }
  }

  /* 三层滚动箭头逐级弹跳动画 */
  @keyframes scrollArrow {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-10px); }
    60% { transform: translateY(-4px); }
  }
</style>
