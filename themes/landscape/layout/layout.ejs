<!DOCTYPE html>
<html>
<%- partial('_partial/head') %>
<body>
  <!-- 背景音乐 — 尊重浏览器自动播放策略，首次用户交互时启动 -->
  <audio loop style="display:none;" id="bgm-player">
    <source src="/music/SAIKAI.mp3" type="audio/mpeg">
  </audio>
  <script>
    (function() {
      var bgm = document.getElementById('bgm-player');
      if (!bgm) return;
      bgm.volume = 0.35;

      // 尝试自动播放（部分浏览器允许）
      var playPromise = bgm.play();
      var isPlaying = false;

      if (playPromise !== undefined) {
        playPromise.then(function() {
          isPlaying = true;
        }).catch(function() {
          // 浏览器阻止了自动播放，等待用户第一次交互
          isPlaying = false;
        });
      }

      // 用户首次交互（点击/触摸/按键/滚动）时启动音乐
      function startOnInteract() {
        if (isPlaying) return;
        bgm.play().then(function() {
          isPlaying = true;
        }).catch(function() {});
        // 启动成功后移除监听
        if (isPlaying) {
          document.removeEventListener('click', startOnInteract);
          document.removeEventListener('touchstart', startOnInteract);
          document.removeEventListener('keydown', startOnInteract);
          document.removeEventListener('scroll', startOnInteract);
        }
      }

      document.addEventListener('click', startOnInteract, { once: true });
      document.addEventListener('touchstart', startOnInteract, { once: true });
      document.addEventListener('keydown', startOnInteract, { once: true });
    })();
  </script>

  <div id="container">
    <div id="wrap">
      <%- partial('_partial/header', null, {cache: !config.relative_link}) %>

      <!-- PJAX 内容容器：包含 Hero + 主内容区，切换页面时整体替换 -->
      <div id="pjax-container">
        <!-- 首页全屏 Hero -->
        <% if (is_home()){ %>
          <%- partial('_partial/hero') %>
        <% } %>

        <div class="outer">
          <section id="main"><%- body %></section>
          <% if (theme.sidebar && theme.sidebar !== 'bottom'){ %>
            <%- partial('_partial/sidebar', null, {cache: !config.relative_link}) %>
          <% } %>
        </div>
      </div>
      <%- partial('_partial/footer', null, {cache: !config.relative_link}) %>
    </div>
    <%- partial('_partial/mobile-nav', null, {cache: !config.relative_link}) %>
    <%- partial('_partial/after-footer') %>
  </div>

</body>
</html>
