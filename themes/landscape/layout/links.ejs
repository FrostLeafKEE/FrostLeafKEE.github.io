<!-- 友链页面布局 -->
<article class="page">
  <div class="page-content">
    <div class="links-intro" style="text-align: center; margin: 20px 0 40px 0;">
      <h2 style="font-family: 'Georgia', 'STKaiti', 'KaiTi', serif; font-size: 42px; font-weight: 700; margin: 0 0 8px 0; color: #4eb8a8; letter-spacing: 6px; text-shadow: 2px 2px 4px rgba(78,184,168,0.2);">友情链接</h2>
      <p style="font-family: 'Georgia', 'STKaiti', 'KaiTi', serif; font-size: 20px; margin: 0; color: #8ba3a0; letter-spacing: 3px; font-style: italic;">霜叶叶的朋友们</p>
    </div>

    <% if (site.data.links && site.data.links.length > 0) { %>
      <div class="links-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; margin-top: 30px;">
        <% site.data.links.forEach(function(link) { %>
          <a href="<%= link.url %>" target="_blank" rel="noopener" class="link-card" style="display: flex; align-items: center; gap: 16px; padding: 20px; border: 1px solid #e0e0e0; border-radius: 12px; text-decoration: none; color: inherit; transition: all 0.3s ease; background: #fff;">
            <img src="<%= link.avatar %>" alt="<%= link.name %>" style="width: 64px; height: 64px; border-radius: 50%; object-fit: cover; flex-shrink: 0;">
            <div class="link-info">
              <h3 style="margin: 0 0 6px 0; font-size: 18px; color: #333;"><%= link.name %></h3>
              <p style="margin: 0; font-size: 14px; color: #666; line-height: 1.5;"><%= link.description %></p>
            </div>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <p style="margin-top: 30px; color: #999; font-style: italic; text-align: center;">暂无友链，快来成为第一个吧~</p>
    <% } %>

    <!-- 申请友链说明 -->
    <div class="links-apply" style="margin-top: 60px; padding: 25px 30px; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 12px; line-height: 1.8;">
      <h2 style="margin: 0 0 15px 0; font-size: 22px; color: #333;">📬 申请友链</h2>
      <p style="margin: 0 0 15px 0; color: #555;">
        您也可以在我的
        <a href="https://github.com/你的GitHub用户名/你的GitHub用户名.github.io" target="_blank" rel="noopener" style="color: #4A90D9; font-weight: 500;">博客仓库</a>
        中提 Issues 并写上您的友链信息，或者在下方评论区直接发布，格式如下：
      </p>
      <pre style="background: #282c34; color: #abb2bf; padding: 20px 24px; border-radius: 8px; font-size: 14px; line-height: 1.7; overflow-x: auto; margin: 0;"><code>name: Your Name
link: https://fika.ink/
avatar: https://pic.imgdb.cn/item/637c14ee16f2c2beb161a26e.jpg
descr: 遇到困难睡大觉</code></pre>
    </div>
  </div>
</article>

<style>
  .link-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.12);
    border-color: #4eb8a8 !important;
  }
</style>
